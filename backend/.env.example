# Copy this file to .env and fill in your values
# (Never commit .env to git)

# ── Google OAuth 2.0 credentials ──────────────────────────────────────
# สร้างได้ที่ console.cloud.google.com → APIs & Services → Credentials
# → Create Credentials → OAuth 2.0 Client IDs → Desktop app (หรือ Web app)
GOOGLE_CLIENT_ID=ใส่ Client ID ที่นี่.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ใส่ Client Secret ที่นี่

# Refresh Token — ขอได้จาก https://developers.google.com/oauthplayground
# 1. คลิกเฟือง ⚙ → ติ๊ก "Use your own OAuth credentials" → ใส่ Client ID & Secret
# 2. เลือก scope: https://www.googleapis.com/auth/drive.readonly
# 3. Authorize APIs → Exchange authorization code for tokens
# 4. คัดลอก Refresh Token มาใส่ที่นี่
GOOGLE_REFRESH_TOKEN=ใส่ Refresh Token ที่นี่

# ── CORS origins ──────────────────────────────────────────────────────
# * = อนุญาตทุก origin (ใช้ได้ระหว่าง dev)
# production ให้ระบุ domain จริง เช่น https://yourdomain.com
ALLOWED_ORIGINS=*

# ── Local performance tuning (ไม่จำเป็นต้องใส่ใน Vercel) ─────────────
# เพิ่มค่าเหล่านี้เมื่อรันบนเครื่องตัวเองเพื่อความเร็วสูงสุด
DRIVE_DL_TIMEOUT=90     # วินาทีต่อไฟล์ (Vercel: 30, Local: 90+)
DRIVE_SEM_LIMIT=6       # concurrent Drive uploads (Vercel: 2, Local: 6)
